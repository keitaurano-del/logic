default_platform(:ios)

WORKSPACE = "App.xcworkspace"
SCHEME = "App"
PROJECT = "App.xcodeproj"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Sync Capacitor web assets and install pods"
  lane :prepare do
    Dir.chdir("../../..") do
      sh("npm", "ci")
      sh("npm", "run", "build")
      sh("npx", "cap", "sync", "ios")
    end
    cocoapods(podfile: "Podfile", repo_update: true)
  end

  desc "Bump CFBundleVersion (build number) using App Store Connect latest + 1"
  lane :bump_build do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: ENV["APP_BUNDLE_ID"] || "io.logic.app",
      initial_build_number: 0,
    )
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: (latest + 1).to_s,
    )
  end

  desc "Build and upload a TestFlight beta"
  lane :beta do
    prepare
    bump_build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )

    match(
      type: "appstore",
      readonly: ENV["CI"] ? false : true,
      api_key: api_key,
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Logic.ipa",
      clean: true,
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["RELEASE_NOTES"] || "Bug fixes and improvements.",
    )
  end

  desc "Build, upload, and submit for App Store review"
  lane :release do
    prepare
    bump_build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )

    match(
      type: "appstore",
      readonly: ENV["CI"] ? false : true,
      api_key: api_key,
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Logic.ipa",
      clean: true,
    )

    upload_to_app_store(
      api_key: api_key,
      force: true,
      submit_for_review: true,
      automatic_release: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        content_rights_contains_third_party_content: false,
      },
    )
  end
end
